NNM_ENV=local
NNM_LOG_LEVEL=INFO
NNM_DB_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
NNM_S3_BUCKET=your-paper-bucket
NNM_S3_REGION=ap-northeast-2
NNM_S3_PREFIX=papers/

# 추출 결과(.json/.md) 보관 위치. bucket 비우면 PDF 버킷 (NNM_S3_PDF_BUCKET) → 기본 버킷 fallback.
# 파일명은 원본 PDF s3_key basename (확장자만 .json/.md 로 교체)
NNM_S3_EXTRACTED_BUCKET=
NNM_S3_EXTRACTED_PREFIX=newnonmuncom-extracted/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
NNM_EMBEDDING_MODEL=BAAI/bge-m3
# 운영(GPU)에서는: NNM_EMBEDDING_DEVICE=cuda, FP16=true, BATCH_SIZE=16~32 권장
NNM_EMBEDDING_DEVICE=cpu
NNM_EMBEDDING_FP16=false
NNM_EMBEDDING_BATCH_SIZE=4
NNM_EMBEDDING_MAX_TOKENS=8192
# ColBERT 는 RAG 에서 미사용 + 디스크 폭증의 주범 → false 유지 권장
NNM_EMBEDDING_COLBERT=false
NNM_EMBEDDING_SPARSE=true
NNM_CHUNK_SIZE_TOKENS=512
NNM_CHUNK_OVERLAP_TOKENS=64
NNM_STORAGE_ROOT=var
NNM_PDF_THREADS=4
# True 면 1차 텍스트 추출 elements=0 인 PDF (= OCR 필요) 를 건너뛰고 ingest 계속 진행.
# OCR 비용/시간이 큰 환경에서 텍스트 PDF 만 우선 처리하고 싶을 때 사용.
NNM_PDF_SKIP_OCR=true

# --- 운영계 publications 매핑 (s3_key → publication_id + title) ---
# 컨테이너 내부 경로. docker-compose.yml 이 호스트의
# publications_*.csv 를 이 경로로 마운트 (read-only).
NNM_PUBLICATION_CSV=/app/data/publications.csv
NNM_PUBLICATION_CSV_ENCODING=cp949

# --- RAG / Groq LLM ---
# Groq 콘솔(https://console.groq.com/keys)에서 발급받은 키를 여기에 넣으세요.
NNM_GROQ_API_KEY=
NNM_GROQ_MODEL=llama-3.3-70b-versatile
NNM_GROQ_BASE_URL=https://api.groq.com/openai/v1
NNM_RAG_TOP_K=5
NNM_RAG_MAX_CONTEXT_CHARS=8000
NNM_RAG_TEMPERATURE=0.2
